{
  "manifest_version": 3,
  "name": "Pixel Sparkle Cursor ✨",
  "version": "2.0",
  "description": "Stardew Valley sprites trail behind your cursor on every webpage!",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Pixel Sparkle Cursor"
  },
  "web_accessible_resources": [
    {
      "resources": ["sprites/*.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
